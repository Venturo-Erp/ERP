              <span style={{ fontSize: '12px', color: COLORS.gray, marginRight: '16px' }}>
                {PRINT_LABELS.LABEL_5145}
              </span>
              <span style={{ fontSize: '13px', fontWeight: 600, color: COLORS.brown }}>
                NT$ {companyTotal.toLocaleString()}
              </span>
            </div>
