            style={{
              fontSize: '15px',
              fontWeight: 700,
              color: COLORS.gold,
            }}
          >
            NT$ {totalAmount.toLocaleString()}
          </span>
        </div>

        {/* 頁尾 */}
        <div
          style={{
            marginTop: '40px',
            textAlign: 'center',
          }}
        >
          <p
            style={{
              fontSize: '11px',
