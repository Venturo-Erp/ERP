# Venturo 環境變數設定檔範本
# 複製此檔案為 .env.local 並填入實際的值

# ============================================
# 安全性設定（Production 必填）
# ============================================
# JWT Secret - 用於驗證登入 token（至少 32 字元的隨機字串）
JWT_SECRET=
# Quick Login Secret - 用於快速登入功能（client + middleware 共用）
NEXT_PUBLIC_QUICK_LOGIN_SECRET=

# ============================================
# 應用配置
# ============================================
NEXT_PUBLIC_APP_NAME=Venturo ERP
NEXT_PUBLIC_APP_URL=http://localhost:1069
NODE_ENV=development

# ============================================
# 功能開關
# ============================================
# 啟用除錯模式
NEXT_PUBLIC_DEBUG_MODE=false

# ============================================
# 開發環境設定
# ============================================
# 開發伺服器 Port
PORT=1069

# 是否啟用 React DevTools
NEXT_PUBLIC_ENABLE_DEVTOOLS=true
# Sentry 錯誤追蹤 (可選)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================
# Unsplash API (免費圖庫搜尋)
# ============================================
# 前往 https://unsplash.com/developers 申請 Access Key
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=

# ============================================
# 台新銀行 LinkPay 設定
# ============================================
# 特店代號 (15碼，向台新銀行申請)
TAISHIN_MID=
# 端末代號 (8碼，向台新銀行申請)
TAISHIN_TID=
# Webhook MAC 驗證密鑰（向台新銀行索取，用於驗證 webhook 請求來源）
TAISHIN_MAC_KEY=

# ============================================
# Supabase 設定
# ============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# CLI 用（非 runtime）
# SUPABASE_ACCESS_TOKEN=

# ============================================
# AI / LLM 設定
# ============================================
# Gemini API（多 key 輪替）
GEMINI_API_KEY=
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# GEMINI_API_KEY_4=
# GEMINI_API_KEY_5=
# 停用 AI 功能
NEXT_PUBLIC_DISABLE_AI=false
# Ollama 本地 LLM（可選）
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ============================================
# OCR / Vision 設定
# ============================================
GOOGLE_VISION_API_KEY=
# 多 key（逗號分隔）
# GOOGLE_VISION_API_KEYS=
OCR_SPACE_API_KEY=

# ============================================
# Google Maps API 設定
# ============================================
# 用於景點座標自動取得（Places API）
# 申請網址：https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ============================================
# 外部 API
# ============================================
# 航班資料
AERODATABOX_API_KEY=
NEXT_PUBLIC_RAPIDAPI_KEY=
# 圖庫
NEXT_PUBLIC_PEXELS_API_KEY=
# 代理（可選）
# QUOTAGUARD_STATIC_URL=

# ============================================
# Venturo Online 連結
# ============================================
NEXT_PUBLIC_ONLINE_URL=http://localhost:3001

# ============================================
# Bot / Cron 安全
# ============================================
BOT_API_SECRET=
CRON_SECRET=

# ============================================
# FastMove API（可選）
# ============================================
# NEXT_PUBLIC_FASTMOVE_API_URL=
# NEXT_PUBLIC_FASTMOVE_API_KEY=

# ============================================
# Demo 體驗帳號（公開，前端可讀取）
# ============================================
# ⚠️ DEPRECATED: 正式上線後已移除 Demo 功能（安全考量）
NEXT_PUBLIC_DEMO_COMPANY_CODE=
NEXT_PUBLIC_DEMO_EMPLOYEE_ID=
NEXT_PUBLIC_DEMO_PASSWORD=

# ============================================
# 日誌設定
# ============================================
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_REMOTE_LOGGING=false
NEXT_PUBLIC_ENABLE_SUPABASE=true

# ============================================
# Messaging Platform (FB/IG 客服整合)
# ============================================
# Meta App Secret（用於驗證 webhook 簽名）
META_APP_SECRET=
# Meta Webhook 驗證 Token（自訂字串）
META_VERIFY_TOKEN=
# Meta Page Access Token（從 Meta Business Suite 取得）
META_PAGE_ACCESS_TOKEN=
# Claude API Key（用於 AI 客服）
CLAUDE_API_KEY=
# 內部管理 API Key（自訂，用於手動設定租戶）
MESSAGING_ADMIN_API_KEY=
