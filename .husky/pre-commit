#!/bin/sh
echo "🔍 Pre-commit checks..."

# 1. TypeScript 型別檢查（整個專案）
echo "📝 Running TypeScript type check..."
NODE_OPTIONS="--max-old-space-size=4096" npm run type-check
if [ $? -ne 0 ]; then
  echo "❌ TypeScript type check failed!"
  echo "💡 Tip: Run 'npm run type-check' to see errors"
  exit 1
fi

# 2. 檢查是否有 @ts-expect-error（絕對禁止）
echo "🚫 Checking for @ts-expect-error..."
FOUND_FILES=$(git diff --cached --name-only | grep -E '\.(ts|tsx)$' | grep -v '.husky' | xargs grep -l "@ts-expect-error" 2>/dev/null || true)
if [ -n "$FOUND_FILES" ]; then
  echo "❌ Found @ts-expect-error in staged files:"
  echo "$FOUND_FILES"
  echo "💡 Fix the type error instead of using @ts-expect-error"
  exit 1
fi

# 3. 檢查 Next.js 15 params Promise（常見錯誤）
echo "🔍 Checking for Next.js 15 params issues..."
PARAMS_ISSUES=$(git diff --cached --name-only | grep -E '\.(ts|tsx)$' | xargs grep -E 'params\.(id|tourId|requestId|[a-z]+)' 2>/dev/null | grep -v 'await params' || true)
if [ -n "$PARAMS_ISSUES" ]; then
  echo "⚠️  Warning: Found direct params access without await"
  echo "💡 Next.js 15 requires: const { id } = await params"
fi

# 4. 檢查 console.log（production 不應該有）
echo "🔍 Checking for console.log..."
CONSOLE_LOGS=$(git diff --cached --name-only | grep -E '\.(ts|tsx)$' | xargs grep -l "console\\.log" 2>/dev/null || true)
if [ -n "$CONSOLE_LOGS" ]; then
  echo "⚠️  Warning: Found console.log in staged files"
  echo "💡 Consider using proper logging or remove debug logs"
fi

# 5. ERP 整理憲法守門（VENTURO_ERP_STANDARDS.md Section 10）
echo "🛡️  Running ERP standards check..."
if [ -x scripts/check-standards.sh ]; then
  scripts/check-standards.sh --strict
  if [ $? -ne 0 ]; then
    echo "❌ ERP standards violations found"
    echo "💡 See docs/VENTURO_ERP_STANDARDS.md Section 10"
    exit 1
  fi
fi

echo "✅ All checks passed!"
