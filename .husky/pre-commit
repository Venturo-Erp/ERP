#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Pre-commit checks..."

# 1. TypeScript 型別檢查（整個專案）
echo "📝 Running TypeScript type check..."
npm run type-check
if [ $? -ne 0 ]; then
  echo "❌ TypeScript type check failed!"
  echo "💡 Tip: Run 'npm run type-check' to see errors"
  exit 1
fi

# 2. ESLint（只檢查 staged files）
echo "🔧 Running ESLint on staged files..."
npx lint-staged
if [ $? -ne 0 ]; then
  echo "❌ ESLint check failed!"
  exit 1
fi

# 3. 檢查是否有 @ts-expect-error（絕對禁止）
echo "🚫 Checking for @ts-expect-error..."
if git diff --cached --name-only | xargs grep -l "@ts-expect-error" 2>/dev/null; then
  echo "❌ Found @ts-expect-error in staged files!"
  echo "💡 Fix the type error instead of using @ts-expect-error"
  exit 1
fi

# 4. 檢查 Next.js 15 params Promise（常見錯誤）
echo "🔍 Checking for Next.js 15 params issues..."
if git diff --cached --name-only | grep -E '\.(ts|tsx)$' | xargs grep -E 'params\.(id|tourId|requestId|[a-z]+)' 2>/dev/null | grep -v 'await params'; then
  echo "⚠️  Warning: Found direct params access without await"
  echo "💡 Next.js 15 requires: const { id } = await params"
fi

# 5. 檢查 console.log（production 不應該有）
echo "🔍 Checking for console.log..."
if git diff --cached --name-only | grep -E '\.(ts|tsx)$' | xargs grep -l "console\\.log" 2>/dev/null; then
  echo "⚠️  Warning: Found console.log in staged files"
  echo "💡 Consider using proper logging or remove debug logs"
fi

# 6. 檢查 Server Component 用 useState/useEffect 但沒有 'use client'
echo "🔍 Checking for Server Component mistakes..."
for file in $(git diff --cached --name-only | grep -E 'src/app/.*\.(ts|tsx)$'); then
  if [ -f "$file" ]; then
    if grep -q "useState\|useEffect" "$file" && ! grep -q "'use client'" "$file"; then
      echo "⚠️  Warning: $file uses React hooks but missing 'use client'"
      echo "💡 Add 'use client' at the top of the file"
    fi
  fi
done

# 7. 檢查 public page 用 anon key 的 insert/update
echo "🔍 Checking for Supabase security issues..."
for file in $(git diff --cached --name-only | grep -E 'src/app/public/.*\.(ts|tsx)$'); do
  if [ -f "$file" ]; then
    if grep -q "\.insert\|\.update\|\.delete" "$file" && grep -q "createClient()" "$file"; then
      echo "⚠️  Warning: $file may use anon key for write operations"
      echo "💡 Public pages should use service role key for writes"
    fi
  fi
done

echo "✅ All checks passed!"
