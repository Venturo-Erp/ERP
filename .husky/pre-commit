#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 執行 pre-commit 代碼品質檢查..."
echo "================================"

# TypeScript 類型檢查（整個專案）
echo ""
echo "🔧 執行 TypeScript 類型檢查..."
if ! npm run type-check --silent; then
  echo "❌ TypeScript 類型檢查失敗！"
  exit 1
fi

# 單元測試
echo ""
echo "🧪 執行單元測試..."
if ! npx vitest run --silent; then
  echo "❌ 單元測試失敗！"
  exit 1
fi

# ESLint 檢查（只檢查 staged files）
echo ""
echo "📋 執行 ESLint 檢查（只檢查 staged files）..."
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -n "$STAGED_FILES" ]; then
  if ! npx eslint $STAGED_FILES; then
    echo "❌ ESLint 檢查失敗！"
    echo "💡 提示：執行 'npm run lint' 查看詳細錯誤"
    exit 1
  fi
else
  echo "ℹ️ 沒有 staged 的 JS/TS 檔案，跳過 ESLint"
fi

echo ""
echo "================================"
echo "✅ 所有 pre-commit 檢查通過！"
echo ""
